{
    "name": "sch-platform",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "update": "ts-node server/src/index.ts",
        "seed": "ts-node server/prisma/seed.ts",
        "ingest": "ts-node server/src/ingest-only.ts",
        "dev": "nodemon --watch server --exec ts-node server/server.ts",
        "build": "tsc && cp -r server/prisma/generated dist/server/prisma/generated",
        "start": "prisma migrate deploy && node dist/server/server.js",
        "postinstall": "prisma generate",
        "setup": "npm install && npm --prefix client install && npx playwright install chromium",
        "db": "prisma generate && prisma migrate dev && npm run ingest",
        "sync": "ts-node server/src/sync.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/cli-progress": "^3.11.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.0.3",
        "nodemon": "^3.1.11",
        "prisma": "^7.2.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.2.0",
        "@prisma/client": "^7.2.0",
        "ansi-colors": "^4.1.3",
        "cli-progress": "^3.12.0",
        "cors": "^2.8.6",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "fuse.js": "^7.1.0",
        "playwright-chromium": "^1.57.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "zod": "^4.3.4"
    }
}
